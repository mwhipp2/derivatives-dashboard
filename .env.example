# ──────────────────────────────────────────────────────────────────────────────
# Schwab Developer API Credentials
# Register your app at: https://developer.schwab.com/
#
# Steps:
#  1. Sign in with your Schwab brokerage account
#  2. Click "Create App"
#  3. Set Callback URL to: https://127.0.0.1
#  4. Copy the App Key and App Secret below
#  5. Rename this file to: .env
# ──────────────────────────────────────────────────────────────────────────────

SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Must match exactly what you entered in the Schwab developer portal
SCHWAB_REDIRECT_URI=https://127.0.0.1
